# Copy this file to .env and set values for your machine.
# Configure one provider key below (or both):
OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Primary provider when both keys exist (anthropic or openai).
PRIMARY_PROVIDER=anthropic

# Pick a model compatible with your key.
MODEL=claude-sonnet-4-6
# MODEL=gpt-4o

# Optional fallback model overrides when the active provider has billing/quota errors.
# OPENAI_FALLBACK_MODEL=gpt-4o
# ANTHROPIC_FALLBACK_MODEL=claude-sonnet-4-6

# Optional API bearer token to protect backend endpoints.
# API_AUTH_TOKEN=replace_with_a_long_random_token

# Optional bridge secret for /api/bridge tokens (falls back to API_AUTH_TOKEN).
# BRIDGE_SECRET=replace_with_a_different_long_random_token
# BRIDGE_TOKEN_TTL_SECONDS=3600

# Optional CORS origins (comma-separated).
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

MAX_TOKENS=8192
PERMISSION_MODE=ask
# Seconds to wait for interactive permission approval before auto-deny.
# PERMISSION_REQUEST_TIMEOUT_SECONDS=120

# Directory safety:
# - By default, users can choose any working directory except blocked system folders.
# - Set STRICT_PATH_ALLOWLIST=1 to enforce ALLOWED_DIRS as a hard allowlist.
# STRICT_PATH_ALLOWLIST=1
# ALLOWED_DIRS=~,.
# Optional extra blocked roots (comma-separated).
# BLOCKED_DIRS=
# Optional override (not recommended): allow system roots too.
# ALLOW_SYSTEM_DIRS=0

MAX_FILE_SIZE_KB=500

# Per-IP endpoint limits.
RATE_LIMIT_SEND_PER_MINUTE=30
RATE_LIMIT_SESSION_PER_MINUTE=20
RATE_LIMIT_MEMORY_PER_MINUTE=10

# Optional pricing overrides (USD per 1M tokens) for usage estimates.
# COST_CLAUDE_INPUT_PER_M=3.0
# COST_CLAUDE_OUTPUT_PER_M=15.0
# COST_OPENAI_INPUT_PER_M=5.0
# COST_OPENAI_OUTPUT_PER_M=15.0