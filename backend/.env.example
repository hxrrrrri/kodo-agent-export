# KODO environment configuration
# Copy to .env and fill what you need.
# Notes:
# - Env vars always override active profile values.
# - Feature flags default to 1 (enabled).

# === PROVIDER - PRIMARY ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
GITHUB_MODELS_TOKEN=
CODEX_API_KEY=

# Compatibility variables used by OpenClaude-style setups.
CLAUDE_CODE_USE_OPENAI=0
CLAUDE_CODE_USE_GEMINI=0
CLAUDE_CODE_USE_GITHUB=0
CLAUDE_CODE_USE_BEDROCK=0
CLAUDE_CODE_USE_VERTEX=0
GITHUB_TOKEN=
GH_TOKEN=

# Fixed-mode provider preference (when multiple keys are present).
PRIMARY_PROVIDER=anthropic
MODEL=claude-sonnet-4-6

# Optional provider base URLs.
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_BASE_URL=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
GROQ_BASE_URL=https://api.groq.com/openai/v1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
GITHUB_MODELS_BASE_URL=https://models.github.ai/inference
CODEX_BASE_URL=https://api.openai.com/v1

# Optional provider-specific model hints.
GEMINI_MODEL=gemini-2.0-flash
BIG_MODEL=
SMALL_MODEL=

# === PROVIDER - FALLBACK ===
OPENAI_FALLBACK_MODEL=gpt-4o
ANTHROPIC_FALLBACK_MODEL=claude-sonnet-4-6

# OpenClaude-compatible tuning flags.
CLAUDE_CODE_MAX_RETRIES=10
CLAUDE_CODE_UNATTENDED_RETRY=0
OPENCLAUDE_ENABLE_EXTENDED_KEYS=0
OPENCLAUDE_DISABLE_CO_AUTHORED_BY=0
API_TIMEOUT_MS=60000
CLAUDE_DEBUG=0

# Bedrock / Vertex compatibility knobs.
AWS_REGION=
AWS_DEFAULT_REGION=
AWS_BEARER_TOKEN_BEDROCK=
ANTHROPIC_BEDROCK_BASE_URL=
ANTHROPIC_VERTEX_PROJECT_ID=
CLOUD_ML_REGION=
GOOGLE_CLOUD_PROJECT=

# === SMART ROUTER ===
ROUTER_MODE=fixed
ROUTER_STRATEGY=balanced
ROUTER_FALLBACK=true
ROUTER_HEALTH_INTERVAL_SECONDS=60

# === LOCAL PROVIDERS ===
OLLAMA_BASE_URL=http://localhost:11434
ATOMIC_CHAT_BASE_URL=http://127.0.0.1:1337

# === WEB SEARCH ===
FIRECRAWL_API_KEY=
TAVILY_API_KEY=
SERPAPI_KEY=
# DuckDuckGo fallback is used automatically when no key above is configured.

# === AGENT BEHAVIOUR ===
MAX_TOKENS=8192
PERMISSION_REQUEST_TIMEOUT_SECONDS=120
MAX_CONTEXT_MESSAGES=50
KODO_ENABLE_PROMPT_CACHE=1
N_CACHE_MESSAGES=4
MAX_UPLOAD_SIZE_MB=50           # max total attachment size for multi-file upload
KODO_ENABLE_STREAMING_TOOLS=1   # stream bash/shell output lines in real time
KODO_ENABLE_AUTO_TITLE=1        # auto-generate smart session titles (>=4 messages)
MAX_STREAMING_LINES=200         # max bash output lines to stream before truncation

# Optional feature flags (1 = enabled, 0 = disabled).
KODO_ENABLE_SMART_ROUTER=1
KODO_ENABLE_PROVIDER_DISCOVERY=1
KODO_ENABLE_DOCTOR=1
KODO_ENABLE_PROFILES=1
KODO_ENABLE_SESSION_RUNNER=1
KODO_ENABLE_COMMAND_EXPANSION=1
KODO_ENABLE_REPL_PERSISTENCE=1
KODO_ENABLE_MEMORY_WRITE=1
KODO_ENABLE_WEBHOOKS=1
KODO_ENABLE_IMAGE_GEN=0   # opt-in: set to 1 to enable DALL-E 3 image generation
KODO_ENABLE_CAVEMAN=0     # opt-in: caveman mode + caveman commands + caveman tool
KODO_ENABLE_TTS=0         # opt-in: set to 1 to enable OpenAI text-to-speech
KODO_ENABLE_COLLAB=0      # opt-in: set to 1 to enable session sharing + collaboration
KODO_ENABLE_KRAWLX=1      # secure crawler endpoint + tool
COLLAB_TOKEN_TTL_SECONDS=3600
KODO_PUBLIC_APP_URL=      # optional: frontend base URL used for share links (e.g. http://localhost:5173)
KODO_ENABLE_SCREENSHOT=0  # opt-in: requires playwright or headless chromium
KODO_ENABLE_DATABASE=1    # auto-disabled if DB_URL is empty
KODO_ENABLE_EMAIL=0       # opt-in: requires SMTP configuration
KODO_ENABLE_CRON=1        # set to 0 to disable scheduled agent runs

# === PERMISSION SYSTEM ===
# ask  -> interactive approval
# auto -> auto approve safe operations
# yolo -> allow everything except hard-blocked patterns
PERMISSION_MODE=ask

# === MEMORY + SESSIONS ===
# Session/model metadata is persisted under ~/.kodo/sessions.
# Profiles persist under ~/.kodo/profiles.json and ~/.kodo/active-profile.json.

# === SECURITY + AUTH ===
API_AUTH_TOKEN=
BRIDGE_SECRET=
BRIDGE_TOKEN_TTL_SECONDS=3600
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# === WEBHOOKS ===
WEBHOOK_SECRET=           # optional HMAC secret for verifying webhook signatures

# === KRAWLX (SECURE CRAWLER) ===
KRAWLX_FORCE_HTTPS=1
KRAWLX_ALLOW_PRIVATE_NETWORKS=0
KRAWLX_ALLOW_NONSTANDARD_PORTS=0
KRAWLX_ALLOWED_HOSTS=
KRAWLX_BLOCKED_HOSTS=localhost,127.0.0.1,::1,169.254.169.254,metadata.google.internal
KRAWLX_MAX_PAGES_DEFAULT=20
KRAWLX_MAX_PAGES_HARD_LIMIT=500
KRAWLX_MAX_DEPTH_DEFAULT=2
KRAWLX_MAX_PAGE_KB=512
KRAWLX_MAX_LINKS_PER_PAGE=500
KRAWLX_MAX_TEXT_CHARS=4000
KRAWLX_MAX_REDIRECTS=5
KRAWLX_HOST_DELAY_MS=200
KRAWLX_USER_AGENT=KrawlXBot/1.0 (+security-first)
KRAWLX_PROVIDER=auto
KRAWLX_FIRECRAWL_FALLBACK=1
KRAWLX_FIRECRAWL_POLL_TIMEOUT_SECONDS=120
KRAWLX_WEBHOOK_CACHE_SIZE=5000
KRAWLX_WEBHOOK_CACHE_TTL_SECONDS=1800

# === DATABASE ===
DB_URL=                   # sqlite:///./mydb.sqlite3 or postgresql://user:pass@host/db

# === SMTP EMAIL ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# === OBSERVABILITY ===
# Request + audit files:
# ~/.kodo/audit/events.jsonl
# ~/.kodo/usage/events.jsonl

# === RATE LIMITS ===
RATE_LIMIT_SEND_PER_MINUTE=30
RATE_LIMIT_SESSION_PER_MINUTE=20
RATE_LIMIT_MEMORY_PER_MINUTE=10
RATE_LIMIT_COMMANDS_PER_MINUTE=120

# === REPL ===
REPL_SESSION_TIMEOUT_SECONDS=300

# === COST TRACKING ===
# Legacy provider overrides (USD per 1M tokens).
COST_CLAUDE_INPUT_PER_M=3.0
COST_CLAUDE_OUTPUT_PER_M=15.0
COST_OPENAI_INPUT_PER_M=2.5
COST_OPENAI_OUTPUT_PER_M=10.0

# Generic per-provider overrides:
# COST_INPUT_PER_M_OPENAI=
# COST_OUTPUT_PER_M_OPENAI=
# COST_INPUT_PER_M_ANTHROPIC=
# COST_OUTPUT_PER_M_ANTHROPIC=
# COST_INPUT_PER_M_GEMINI=
# COST_OUTPUT_PER_M_GEMINI=
# COST_INPUT_PER_M_DEEPSEEK=
# COST_OUTPUT_PER_M_DEEPSEEK=
# COST_INPUT_PER_M_GROQ=
# COST_OUTPUT_PER_M_GROQ=
# COST_INPUT_PER_M_OPENROUTER=
# COST_OUTPUT_PER_M_OPENROUTER=
# COST_INPUT_PER_M_OLLAMA=
# COST_OUTPUT_PER_M_OLLAMA=
# COST_INPUT_PER_M_ATOMIC_CHAT=
# COST_OUTPUT_PER_M_ATOMIC_CHAT=

# === PRIVACY ===
# Set to 1 to disable local usage/audit event writes.
KODO_NO_TELEMETRY=0

# === CRON SCHEDULER ===
# Runtime cron jobs are persisted in ~/.kodo/cron.json

# === MARKETPLACE ===
# No config needed; uses ~/.kodo directories

# === SETTINGS API ===
# No config needed; reads/writes os.environ at runtime

# === PATH GUARD ===
STRICT_PATH_ALLOWLIST=0
ALLOWED_DIRS=~,.
BLOCKED_DIRS=
ALLOW_SYSTEM_DIRS=0
MAX_FILE_SIZE_KB=500

# -- code-review-graph (optional) --------------------------------------
# Set to absolute path of the repo to analyze. Auto-detected if blank.
CRG_REPO_ROOT=
# Embedding model for semantic search (requires pip install code-review-graph[embeddings])
CRG_EMBEDDING_MODEL=all-MiniLM-L6-v2
# Google Gemini API key for cloud embeddings (optional)
GOOGLE_API_KEY=
# Max parallel parse workers (default: min(cpu_count, 8))
CRG_PARSE_WORKERS=4
# Disable CRG integration entirely (set to "1" to disable)
CRG_DISABLED=
