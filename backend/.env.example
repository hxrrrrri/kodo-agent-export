# Copy this file to .env and set values for your machine.
# Configure one provider key below (or both):
OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Primary provider when both keys exist (anthropic or openai).
PRIMARY_PROVIDER=anthropic

# Pick a model compatible with your key.
MODEL=claude-sonnet-4-6
# MODEL=gpt-4o

# Optional fallback model overrides when the active provider has billing/quota errors.
# OPENAI_FALLBACK_MODEL=gpt-4o
# ANTHROPIC_FALLBACK_MODEL=claude-sonnet-4-6

MAX_TOKENS=8192
PERMISSION_MODE=ask
ALLOWED_DIRS=~,/tmp,/home
MAX_FILE_SIZE_KB=500